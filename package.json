{
  "name": "tipping-gates-app",
  "private": true,
  "version": "0.21.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:lockfile": "node scripts/check-lockfile-public-registry.mjs",
    "verify": "npm run check:lockfile && npm run typecheck && npm run test:smoke && npm run build",
    "test:smoke": "rm -rf .test-build && tsc --project tsconfig.smoke.json && node .test-build/tests/scoring-smoke-tests.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3"
  },
  "packageManager": "npm@11.5.1"
}
