# --- Supabase client (browser-visible; safe to expose) ----------------------
# These two vars gate the entire app behind email+password sign-in — if
# unset, the app has NO access control at all and anyone with the URL has
# full access, including tennis predictions that consume your metered quota.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Belt-and-suspenders check on top of the login itself: only a session with
# this exact email is treated as authorized. Since there's no self-service
# sign-up anywhere in this app, the login form alone should already be
# enough (only your one manually-created account can ever sign in) — this
# is just a second layer in case public sign-ups ever get left enabled in
# the Supabase project by mistake. Safe to leave public: on its own, knowing
# this address doesn't grant access. Required — if unset, the app fails
# closed and nobody (including you) can get in.
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com

# One-time Supabase setup, required before sign-in works:
#   1. Authentication -> Users -> Add user -> enter your email + a password
#      -> toggle "Auto Confirm User" on (so it doesn't wait on a confirmation
#      email) -> Create user. That's your one and only account.
#   2. Authentication -> Settings -> turn OFF "Allow new users to sign up"
#      (or equivalent "Enable email signups" toggle), so nobody else can
#      ever create an account through the app, only this one you made.

# --- Supabase server-only (cron job) — never expose these client-side -------
# Same project as above; SUPABASE_URL can be identical to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Live fixtures automation and maintenance (P21/P22) ------------------------------------------
# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# Random string you choose. Set the same value in Vercel's env vars; Vercel
# automatically sends it as a Bearer token when triggering the scheduled cron job.
CRON_SECRET=generate-a-long-random-string

# P22: the same CRON_SECRET is also used by the admin maintenance route
# /api/admin/live-fixtures for manual refresh/status/cleanup from the app UI.

# --- Tennis (Matchstat Tennis API, RapidAPI) ---------------------------------
# Subscribe to "Tennis API - ATP WTA ITF" on RapidAPI and pick the Basic ($0.00)
# plan: https://rapidapi.com/jjrm365-kIFr3Nx_odV/api/tennis-api-atp-wta-itf
# Confirmed limits on that plan: 50 requests/day (hard limit), 4 req/second.
# One player-list load = 1 request. One prediction = 2 requests (recent form
# for both players). That's roughly 20+ predictions/day before hitting the cap.
MATCHSTAT_API_KEY=your-rapidapi-key

